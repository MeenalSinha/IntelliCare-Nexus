# IntelliCare Nexus - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# AI / LLM CONFIGURATION
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================
# DATABASE
# =============================================
POSTGRES_PASSWORD=intellicare_dev
DATABASE_URL=postgresql+asyncpg://intellicare:intellicare_dev@localhost:5432/intellicare

# =============================================
# REDIS
# =============================================
REDIS_URL=redis://localhost:6379

# =============================================
# VECTOR DATABASE
# =============================================
CHROMA_URL=http://localhost:8001

# =============================================
# SECURITY
# =============================================
SECRET_KEY=change_this_to_a_long_random_secret_key_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================
# FHIR SERVER
# =============================================
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4

# =============================================
# CLINICAL TRIALS API
# =============================================
CLINICAL_TRIALS_API_URL=https://clinicaltrials.gov/api/v2

# =============================================
# APPLICATION
# =============================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# =============================================
# FRONTEND
# =============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
